  "components": {
    "schemas": {
      "Azubi": {
        "required": [
          "email",
          "firstName",
          "lastName",
          "passwordhash"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "passwordhash": {
            "minLength": 1,
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "adminRights": {
            "type": "boolean"
          },
          "isDeleted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Dienst": {
        "required": [
          "bezeichnung",
          "intervall"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "bezeichnung": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "beschreibung": {
            "type": "string",
            "nullable": true
          },
          "intervall": {
            "$ref": "#/components/schemas/IntervallEnum"
          },
          "wochentage": {
            "type": "string",
            "nullable": true
          },
          "icon": {
            "type": "string",
            "nullable": true
          },
          "isDeleted": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "IntervallEnum": {
        "enum": [
          "Täglich",
          "Wöchentlich",
          "Monatlich"
        ],
        "type": "string"
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ZuweisungDto": {
        "type": "object",
        "properties": {
          "dienstId": {
            "type": "integer",
            "format": "int32"
          },
          "azubiId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "datum": {
            "type": "string",
            "format": "date-time"
          },
          "istFeiertag": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  }
